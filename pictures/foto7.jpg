<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1280 720" width="1280" height="720">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#0d0e10"/>
      <stop offset="100%" stop-color="#1a1c20"/>
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="4" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>
  <rect width="1280" height="720" fill="url(#bg)"/>
  <g opacity="0.07" stroke="#22d3ee" stroke-width="0.8">
    <line x1="0" y1="80" x2="1280" y2="80"/><line x1="0" y1="160" x2="1280" y2="160"/>
    <line x1="0" y1="240" x2="1280" y2="240"/><line x1="0" y1="320" x2="1280" y2="320"/>
    <line x1="0" y1="400" x2="1280" y2="400"/><line x1="0" y1="480" x2="1280" y2="480"/>
    <line x1="0" y1="560" x2="1280" y2="560"/><line x1="0" y1="640" x2="1280" y2="640"/>
    <line x1="80" y1="0" x2="80" y2="720"/><line x1="160" y1="0" x2="160" y2="720"/>
    <line x1="320" y1="0" x2="320" y2="720"/><line x1="480" y1="0" x2="480" y2="720"/>
    <line x1="640" y1="0" x2="640" y2="720"/><line x1="800" y1="0" x2="800" y2="720"/>
    <line x1="960" y1="0" x2="960" y2="720"/><line x1="1120" y1="0" x2="1120" y2="720"/>
    <line x1="1200" y1="0" x2="1200" y2="720"/>
  </g>
  <!-- Icon: cosplay helmet/mask -->
  <g transform="translate(580, 210)" filter="url(#glow)" stroke="#22d3ee" stroke-width="2.5" fill="none">
    <path d="M60 50 Q60 10 120 10 Q180 10 180 50 L180 140 Q180 170 120 170 Q60 170 60 140 Z"/>
    <path d="M80 90 L110 90" stroke-width="2"/><path d="M130 90 L160 90" stroke-width="2"/>
    <path d="M80 115 Q120 130 160 115" stroke-width="1.5"/>
    <line x1="60" y1="60" x2="30" y2="80"/><line x1="180" y1="60" x2="210" y2="80"/>
  </g>
  <g stroke="#22d3ee" stroke-width="2" fill="none" opacity="0.7">
    <path d="M20,20 L20,50 M20,20 L50,20"/><path d="M1260,20 L1230,20 M1260,20 L1260,50"/>
    <path d="M20,700 L50,700 M20,700 L20,670"/><path d="M1260,700 L1230,700 M1260,700 L1260,670"/>
  </g>
  <text x="640" y="530" text-anchor="middle" font-family="monospace" font-size="14" fill="#22d3ee" opacity="0.7" letter-spacing="6">PROP DE COSPLAY</text>
  <text x="640" y="560" text-anchor="middle" font-family="monospace" font-size="11" fill="#6b7580" letter-spacing="4">FOTO EM BREVE</text>
</svg>
